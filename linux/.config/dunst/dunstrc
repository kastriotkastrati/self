[global]
    font = "Poppins"
    markup = full
    sort = yes
    indicate_hidden = yes
    alignment = left
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    idle_threshold = 120
    monitor = 0
    follow = mouse
    sticky_history = yes
    line_height = 0
    background = "#1a1b1d"
    foreground = "#eeeeee"
    timeout = 5
    gap_size = 5
    corner_radius = 10
    padding = 10
    frame_color = "#1a1b1d"
    frame_width = 2
    transparency = 0
    format = "<b>%s</b>\n%b"
    separator_height = 2
    icon_position = off
    mouse_left_click = do_action,open_url,close_current
    mouse_middle_click = context
    mouse_right_click = close_current
    browser = /usr/bin/xdg-open

[urgency_critical]
    background = "#1a1b1d"
    foreground = "#ffffff"

[urgency_normal]
    background = "#1a1b1d"
    foreground = "#ffffff"

[urgency_low]
    background = "#1a1b1d"
    foreground = "#ffffff"

[slack-mrkdwn-rewrite]
    appname = "Slack"
    body = "*<*|*>*"
    script = /home/kastriotkastrati/.config/dunst/mrkdwn-clean.sh
    skip_display = yes
    history_ignore = yes
